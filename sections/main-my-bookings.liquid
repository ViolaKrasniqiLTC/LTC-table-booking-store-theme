{{ 'my-bookings.css' | asset_url | stylesheet_tag }}
<script src="{{ 'my-bookings.js' | asset_url }}" defer="defer"></script>

<div class="my-bookings">
  {% unless customer %}
    <header class="my-bookings__header">
      <div class="my-bookings__empty">
        <p>
          Please <a href="{{ routes.account_login_url }}?return_url={{ request.path }}">login</a> to view your bookings.
        </p>
      </div>
    </header>
  {% endunless %}

  {% if customer %}
    {% paginate shop.metaobjects.booking.values by 250 %}
      {% assign has_bookings = false %}
      {% assign upcoming_count = 0 %}
      {% assign past_count = 0 %}
      {% assign cancelled_count = 0 %}
      {% assign cancelled_ids = '' %}
      {% assign completed_ids = '' %}

      {% for booking in shop.metaobjects.booking.values %}
        {% include 'booking-belongs-to-customer', booking: booking, customer: customer %}
        {% if booking_belongs %}
          {% assign has_bookings = true %}
          {% assign status = booking.status.value | default: 'Booked' | downcase %}
          {% assign guard_order = booking.order_reference.value | default: booking.order.value %}
          {% assign guard_booking_id = booking.booking_id.value | default: guard_order.name | default: '' %}
          {% assign guard_id = guard_booking_id | remove: 'Booking' | strip | replace: '#', '' | strip | downcase %}
          {% if status == 'cancelled' or status == 'canceled' %}
            {% assign cancelled_count = cancelled_count | plus: 1 %}
            {% if guard_id != blank %}
              {% if cancelled_ids != blank %}
                {% assign cancelled_ids = cancelled_ids | append: '|' %}
              {% endif %}
              {% assign cancelled_ids = cancelled_ids | append: guard_id %}
            {% endif %}
          {% elsif status == 'completed' %}
            {% assign past_count = past_count | plus: 1 %}
            {% if guard_id != blank %}
              {% if completed_ids != blank %}
                {% assign completed_ids = completed_ids | append: '|' %}
              {% endif %}
              {% assign completed_ids = completed_ids | append: guard_id %}
            {% endif %}
          {% else %}
            {% assign upcoming_count = upcoming_count | plus: 1 %}
          {% endif %}
        {% endif %}
      {% endfor %}

      {% if has_bookings %}
        <div class="my-bookings__toolbar">
          <div class="my-bookings__tabs" role="tablist" aria-label="Booking filters">
            <button
              type="button"
              class="my-bookings__tab my-bookings__tab--active"
              role="tab"
              aria-selected="true"
              data-filter="upcoming"
            >
              Upcoming ({{ upcoming_count }})
            </button>
            <button
              type="button"
              class="my-bookings__tab"
              role="tab"
              aria-selected="false"
              data-filter="past"
            >
              Past ({{ past_count }})
            </button>
            <button
              type="button"
              class="my-bookings__tab"
              role="tab"
              aria-selected="false"
              data-filter="cancelled"
            >
              Cancelled ({{ cancelled_count }})
            </button>
          </div>

          <div class="my-bookings__sort">
            <label class="visually-hidden" for="my-bookings-sort">Sort bookings</label>
            <select id="my-bookings-sort" class="my-bookings__sort-select">
              <option value="newest">Newest first</option>
              <option value="oldest">Oldest first</option>
            </select>
          </div>
        </div>
      {% endif %}

      <div class="my-bookings__layout{% if upcoming_count > 0 and section.blocks.size > 0 %} my-bookings__layout--with-form{% else %} my-bookings__layout--narrow{% endif %}">
        <div id="my-bookings-list" class="my-bookings__list">
          {% for booking in shop.metaobjects.booking.values %}
            {% include 'booking-belongs-to-customer', booking: booking, customer: customer %}
            {% if booking_belongs %}
              {% assign order = matched_order %}
              {% assign booking_customer = booking.customer.value %}
              {% assign booking_order = booking.order_reference.value | default: booking.order.value %}
              {% assign status = booking.status.value | default: 'Booked' %}
              {% assign status_class = status | strip | downcase %}
              {% assign booking_id = booking.booking_id.value | default: order.name %}
              {% assign table_product = booking.table.value %}
              {% assign table_image = table_product.featured_media | default: table_product.featured_image %}
              {% assign category = 'upcoming' %}
              {% if status_class == 'cancelled' or status_class == 'canceled' %}
                {% assign category = 'cancelled' %}
              {% elsif status_class == 'completed' %}
                {% assign category = 'past' %}
              {% endif %}
              {% assign copy_booking_id = booking_id | remove: 'Booking' | strip | replace: '#', '' | prepend: '#' %}

              <article
                class="my-bookings__card{% unless category == 'upcoming' %} my-bookings__card--hidden{% endunless %}"
                data-category="{{ category }}"
                data-order-date="{{ booking.date.value | date: '%s' }}"
                data-booking-id="{{ copy_booking_id | escape }}"
              >
                <div class="my-bookings__card-media">
                  {% if table_image %}
                    {{
                      table_image
                      | image_url: width: 700
                      | image_tag:
                        loading: 'lazy',
                        class: 'my-bookings__card-image',
                        alt: table_product.title
                    }}
                  {% else %}
                    <div class="my-bookings__card-image-placeholder">
                      {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
                    </div>
                  {% endif %}
                </div>

                <div class="my-bookings__card-content">
                  <div class="my-bookings__card-top">
                    <div class="my-bookings__card-id-row">
                      <p class="my-bookings__card-id">
                        Booking
                        <span class="my-bookings__card-id-value">{{ copy_booking_id }}</span>
                      </p>
                      <button
                        type="button"
                        class="my-bookings__copy-id"
                        data-copy-id="{{ copy_booking_id | escape }}"
                        aria-label="Copy booking ID {{ copy_booking_id | escape }}"
                        title="Copy booking ID"
                      >
                        <span class="my-bookings__copy-id-icon" aria-hidden="true">
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                          </svg>
                        </span>
                        <span class="my-bookings__copy-id-done" aria-hidden="true" hidden>
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="20 6 9 17 4 12"></polyline>
                          </svg>
                        </span>
                      </button>
                    </div>
                    <span class="my-bookings__status my-bookings__status--{{ status_class }}">
                      {{ status }}
                    </span>
                  </div>

                  <dl class="my-bookings__card-body">
                    <div class="my-bookings__meta">
                      <dt>Table</dt>
                      <dd>{{ booking.table.value.title | default: '—' }}</dd>
                    </div>
                    <div class="my-bookings__meta">
                      <dt>Date</dt>
                      <dd>{{ booking.date.value | default: '—' }}</dd>
                    </div>
                    <div class="my-bookings__meta">
                      <dt>Customer</dt>
                      <dd>
                        {% if booking_customer.first_name != blank %}
                          {{ booking_customer.first_name }} {{ booking_customer.last_name }}
                        {% else %}
                          {{ customer.name }}
                        {% endif %}
                      </dd>
                    </div>
                    <div class="my-bookings__meta">
                      <dt>Email</dt>
                      <dd>{{ booking.customer_email.value | default: booking_customer.email | default: customer.email }}</dd>
                    </div>
                    <div class="my-bookings__meta">
                      <dt>Order reference</dt>
                      <dd>{{ booking_order.name | default: order.name | default: '—' }}</dd>
                    </div>
                    <div class="my-bookings__meta">
                      <dt>Order date</dt>
                      <dd>
                        {% if order %}
                          {{ order.created_at | date: '%d %b %Y' }}
                        {% else %}
                          —
                        {% endif %}
                      </dd>
                    </div>
                  </dl>
                </div>
              </article>
            {% endif %}
          {% endfor %}
        </div>

        {% if upcoming_count > 0 and section.blocks.size > 0 %}
          <aside class="my-bookings__form">
            <p class="my-bookings__cancel-error" data-cancel-error hidden role="alert"></p>
            {% for block in section.blocks %}
              {% render block %}
            {% endfor %}
          </aside>
        {% endif %}
      </div>

      <p class="my-bookings__empty-tab" hidden>No bookings in this category.</p>

      <nav class="my-bookings__pagination" hidden aria-label="Bookings pagination">
        <button type="button" class="my-bookings__pagination-btn" data-pagination="prev" aria-label="Previous page">
          Previous
        </button>
        <p class="my-bookings__pagination-status" aria-live="polite"></p>
        <button type="button" class="my-bookings__pagination-btn" data-pagination="next" aria-label="Next page">
          Next
        </button>
      </nav>

      {% unless has_bookings %}
        <div class="my-bookings__empty">
          <p>You do not have any bookings yet.</p>
        </div>
      {% endunless %}

      <script>
        window.bookingCancelGuard = {
          cancelledIds: {% if cancelled_ids != blank %}{{ cancelled_ids | split: '|' | json }}{% else %}[]{% endif %},
          completedIds: {% if completed_ids != blank %}{{ completed_ids | split: '|' | json }}{% else %}[]{% endif %}
        };
      </script>

    {% endpaginate %}
  {% endif %}
</div>

{% schema %}
{
  "name": "My Bookings",
  "settings": [],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "My Bookings"
    }
  ]
}
{% endschema %}

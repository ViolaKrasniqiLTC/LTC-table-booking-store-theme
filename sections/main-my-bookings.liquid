{{ 'my-bookings.css' | asset_url | stylesheet_tag }}
<script src="{{ 'my-bookings.js' | asset_url }}" defer="defer"></script>

<div class="my-bookings">
  <header class="my-bookings__header">
    <h1 class="my-bookings__title">My Bookings</h1>

    {% unless customer %}
      <div class="my-bookings__empty">
        <p>
          Please <a href="{{ routes.account_login_url }}?return_url={{ request.path }}">login</a> to view your bookings.
        </p>
      </div>
    {% else %}
      <p class="my-bookings__subtitle">Your upcoming and past table reservations.</p>
    {% endunless %}
  </header>

  {% if customer %}
    {% paginate customer.orders by 20 %}
      {% assign has_bookings = false %}
      {% assign upcoming_count = 0 %}
      {% assign past_count = 0 %}
      {% assign cancelled_count = 0 %}

      {% for order in customer.orders %}
        {% assign booking = order.metafields.custom.booking.value %}
        {% if booking %}
          {% assign has_bookings = true %}
          {% assign status = booking.status.value | default: 'Booked' | downcase %}
          {% if status == 'cancelled' %}
            {% assign cancelled_count = cancelled_count | plus: 1 %}
          {% elsif status == 'completed' %}
            {% assign past_count = past_count | plus: 1 %}
          {% else %}
            {% assign upcoming_count = upcoming_count | plus: 1 %}
          {% endif %}
        {% endif %}
      {% endfor %}

      {% if has_bookings %}
        <div class="my-bookings__toolbar">
          <div class="my-bookings__tabs" role="tablist" aria-label="Booking filters">
            <button
              type="button"
              class="my-bookings__tab my-bookings__tab--active"
              role="tab"
              aria-selected="true"
              data-filter="upcoming"
            >
              Upcoming ({{ upcoming_count }})
            </button>
            <button
              type="button"
              class="my-bookings__tab"
              role="tab"
              aria-selected="false"
              data-filter="past"
            >
              Past ({{ past_count }})
            </button>
            <button
              type="button"
              class="my-bookings__tab"
              role="tab"
              aria-selected="false"
              data-filter="cancelled"
            >
              Cancelled ({{ cancelled_count }})
            </button>
          </div>

          <div class="my-bookings__sort">
            <label class="visually-hidden" for="my-bookings-sort">Sort bookings</label>
            <select id="my-bookings-sort" class="my-bookings__sort-select">
              <option value="newest">Newest first</option>
              <option value="oldest">Oldest first</option>
            </select>
          </div>
        </div>
      {% endif %}

      <div id="my-bookings-list" class="my-bookings__list">
        {% for order in customer.orders %}
          {% assign booking = order.metafields.custom.booking.value %}

          {% if booking %}
            {% assign status = booking.status.value | default: 'Booked' %}
            {% assign status_class = status | strip | downcase %}
            {% assign detail_id = order.name | handleize %}
            {% assign table_product = booking.table.value %}
            {% assign table_image = table_product.featured_media | default: table_product.featured_image %}
            {% assign booking_id = booking.booking_id.value | default: order.name %}
            {% assign booking_customer = booking.customer.value %}
            {% assign category = 'upcoming' %}
            {% if status_class == 'cancelled' or status_class == 'canceled' %}
              {% assign category = 'cancelled' %}
            {% elsif status_class == 'completed' %}
              {% assign category = 'past' %}
            {% endif %}

            <article
              class="my-bookings__card{% unless category == 'upcoming' %} my-bookings__card--hidden{% endunless %}"
              data-category="{{ category }}"
              data-order-date="{{ order.created_at | date: '%s' }}"
            >
              <div class="my-bookings__card-media">
                {% if table_image %}
                  {{
                    table_image
                    | image_url: width: 700
                    | image_tag:
                      loading: 'lazy',
                      class: 'my-bookings__card-image',
                      alt: table_product.title
                  }}
                {% else %}
                  <div class="my-bookings__card-image-placeholder">
                    {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
                  </div>
                {% endif %}
              </div>

              <div class="my-bookings__card-content">
                <div class="my-bookings__card-top">
                  <p class="my-bookings__card-id">
                    {%- if booking_id contains 'Booking' or booking_id contains 'BK' -%}
                      {{ booking_id }}
                    {%- else -%}
                      Booking #{{ booking_id }}
                    {%- endif -%}
                  </p>
                  <span class="my-bookings__status my-bookings__status--{{ status_class }}">
                    {{ status }}
                  </span>
                </div>

                <dl class="my-bookings__card-body">
                  <div class="my-bookings__meta">
                    <dt>Table</dt>
                    <dd>{{ booking.table.value.title | default: '—' }}</dd>
                  </div>
                  <div class="my-bookings__meta">
                    <dt>Date</dt>
                    <dd>{{ booking.date.value | default: '—' }}</dd>
                  </div>
                  <div class="my-bookings__meta">
                    <dt>Customer</dt>
                    <dd>
                      {% if booking_customer.first_name != blank %}
                        {{ booking_customer.first_name }} {{ booking_customer.last_name }}
                      {% else %}
                        {{ customer.name }}
                      {% endif %}
                    </dd>
                  </div>
                  <div class="my-bookings__meta">
                    <dt>Total</dt>
                    <dd>{{ order.total_net_amount | money_with_currency }}</dd>
                  </div>
                </dl>

                <div class="my-bookings__card-action">
                  <a href="#booking-{{ detail_id }}" class="my-bookings__button">
                    View details
                  </a>
                </div>
              </div>
            </article>
          {% endif %}
        {% endfor %}
      </div>

      <p class="my-bookings__empty-tab" hidden>No bookings in this category.</p>

      {% unless has_bookings %}
        <div class="my-bookings__empty">
          <p>You do not have any bookings yet.</p>
        </div>
      {% endunless %}

      {% for order in customer.orders %}
        {% assign booking = order.metafields.custom.booking.value %}

        {% if booking %}
          {% assign detail_id = order.name | handleize %}
          {% assign booking_id = booking.booking_id.value | default: order.name %}
          {% assign detail_status = booking.status.value | default: 'Booked' | strip | downcase %}
          {% assign detail_category = 'upcoming' %}
          {% if detail_status == 'cancelled' or detail_status == 'canceled' %}
            {% assign detail_category = 'cancelled' %}
          {% elsif detail_status == 'completed' %}
            {% assign detail_category = 'past' %}
          {% endif %}

          <div id="booking-{{ detail_id }}" class="booking-details">
            <a href="#my-bookings-list" class="booking-details__back">← Back to all bookings</a>
            <div class="booking-details__header">
              <h2 class="booking-details__title">
                {%- if booking_id contains 'Booking' or booking_id contains 'BK' -%}
                  {{ booking_id }}
                {%- else -%}
                  Booking #{{ booking_id }}
                {%- endif -%}
              </h2>
              <span class="my-bookings__status my-bookings__status--{{ detail_status }}">
                {{ booking.status.value | default: 'Booked' }}
              </span>
            </div>
            {% render 'booking-details',
              booking: booking,
              order: order,
              customer: customer,
              detail_id: detail_id,
              show_cancel: detail_category == 'upcoming'
            %}
          </div>
        {% endif %}
      {% endfor %}

      {% if has_bookings %}
        {% assign cancel_return_url = request.path | append: '?cancel_submitted=1' %}

        {% form 'contact', id: 'BookingCancelForm', return_to: cancel_return_url, class: 'booking-cancel__form' %}
          {% if form.posted_successfully? and request.params.cancel_submitted == '1' %}
            <div class="booking-cancel__success booking-cancel__success--global" role="status">
              <p class="booking-cancel__success-title">Cancellation request submitted</p>
              <p class="booking-cancel__success-text">
                Your request has been sent to our team. We will review it and get back to you by email.
              </p>
            </div>
          {% endif %}

          <dialog class="booking-cancel__dialog" id="booking-cancel-dialog" aria-labelledby="booking-cancel-title">
            <div class="booking-cancel__dialog-inner">
              <button type="button" class="booking-cancel__close" data-cancel-close aria-label="Close">
                &times;
              </button>

              <h3 class="booking-cancel__title" id="booking-cancel-title">Request cancellation</h3>
              <p class="booking-cancel__intro">
                Submit a cancellation request for this booking. Our team will review it and contact you by email.
              </p>

              <dl class="booking-cancel__summary">
                <div class="booking-cancel__summary-row">
                  <dt>Booking</dt>
                  <dd data-cancel-summary="booking-id"></dd>
                </div>
                <div class="booking-cancel__summary-row">
                  <dt>Table</dt>
                  <dd data-cancel-summary="table"></dd>
                </div>
                <div class="booking-cancel__summary-row">
                  <dt>Date</dt>
                  <dd data-cancel-summary="date"></dd>
                </div>
              </dl>

              <input type="hidden" name="contact[tags]" value="cancellation-request">
              <input type="hidden" name="contact[name]" value="" data-cancel-name>
              <input type="hidden" name="contact[body]" value="" data-cancel-body>

              <div class="booking-cancel__field">
                <label class="booking-cancel__label" for="BookingCancelForm-email">Email</label>
                <input
                  type="email"
                  id="BookingCancelForm-email"
                  class="booking-cancel__input"
                  name="contact[email]"
                  value=""
                  data-cancel-email
                  autocomplete="email"
                  required
                >
              </div>

              <div class="booking-cancel__field">
                <label class="booking-cancel__label" for="BookingCancelForm-reason">
                  Reason <span class="booking-cancel__optional">(optional)</span>
                </label>
                <textarea
                  id="BookingCancelForm-reason"
                  class="booking-cancel__textarea"
                  rows="4"
                  placeholder="Tell us why you would like to cancel this booking"
                  data-cancel-reason
                ></textarea>
              </div>

              {% if form.errors %}
                <p class="booking-cancel__error" role="alert">
                  Please check your email address and try again.
                </p>
              {% endif %}

              <div class="booking-cancel__actions">
                <button type="button" class="booking-cancel__secondary" data-cancel-close>Cancel</button>
                <button type="submit" class="booking-cancel__submit">Submit request</button>
              </div>
            </div>
          </dialog>
        {% endform %}
      {% endif %}

    {% endpaginate %}
  {% endif %}
</div>

{% schema %}
{
  "name": "My Bookings",
  "settings": [],
  "presets": [
    {
      "name": "My Bookings"
    }
  ]
}
{% endschema %}

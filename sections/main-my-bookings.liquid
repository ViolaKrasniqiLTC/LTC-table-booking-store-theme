<div class="my-bookings">
    <h1> My Bookings</h1>
{% unless customer %}
    <p>Please <a href="{{ routes.account_login_url }}?return_url={{ request.path }}">login</a> to view your bookings.</p>
{% else %}
    {% paginate customer.orders by 20 %}
      {% assign has_bookings = false %}
  
      <div class="my-bookings__list">
        {% for order in customer.orders %}
          {% assign booking = order.metafields.custom.booking.value %}

          {% if booking %}
            {% assign has_bookings = true %}
            {% assign status = booking.status.value | default: 'Booked' %}
            {% assign status_class = status | downcase %}

            <article class="my-bookings__card">
              <div class="my-bookings__card-header">
                <p><strong>{{ booking.booking_id.value | default: 'Booking' }}</strong></p>
                <span class="my-bookings__status my-bookings__status--{{ status_class }}">
                  {{ status }}
                </span>
              </div>

              <dl class="my-bookings__details">
                <div class="my-bookings__detail">
                  <dt>Booking ID</dt>
                  <dd>{{ booking.booking_id.value | default: '—' }}</dd>
                </div>

                <div class="my-bookings__detail">
                  <dt>Customer</dt>
                  <dd>{{ booking.customer.value | default: customer.name }}</dd>
                </div>

                <div class="my-bookings__detail">
                  <dt>Customer email</dt>
                  <dd>{{ booking.customer_email.value | default: customer.email }}</dd>
                </div>

                <div class="my-bookings__detail">
                  <dt>Order reference</dt>
                  <dd>{{ booking.order_reference.value | default: order.name }}</dd>
                </div>

                <div class="my-bookings__detail">
                  <dt>Order ID</dt>
                  <dd>{{ booking.order_id.value | default: order.name }}</dd>
                </div>

                <div class="my-bookings__detail">
                  <dt>Table</dt>
                  <dd>{{ booking.table.value.title | default: '—' }}</dd>
                </div>

                <div class="my-bookings__detail">
                  <dt>Date</dt>
                  <dd>{{ booking.date.value | default: '—' }}</dd>
                </div>

                <div class="my-bookings__detail">
                  <dt>Total</dt>
                  <dd>{{ order.total_net_amount | money_with_currency }}</dd>
                </div>
              </dl>

              <a href="{{ order.customer_url }}" class="button button--secondary">
                View details
              </a>
            </article>
          {% endif %}
        {% endfor %}
      </div>
  
      {% unless has_bookings %}
        <p>You do not have any bookings yet.</p>
      {% endunless %}

    {% endpaginate %}
  {% endunless %}
</div>
<style>
    .my-bookings__list {
      display: grid;
      gap: 1.5rem;
      margin-top: 2rem;
    }
    @media (min-width: 750px) {
      .my-bookings__list {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    .my-bookings__card {
      border: 1px solid #ddd;
      border-radius: 8px;
      padding: 1.5rem;
    }
    .my-bookings__card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
      gap: 1rem;
    }
    .my-bookings__details {
      display: grid;
      gap: 0.8rem;
      margin: 0 0 1.5rem;
    }
    .my-bookings__detail {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      padding-bottom: 0.8rem;
      border-bottom: 1px solid #eee;
    }
    .my-bookings__detail:last-child {
      border-bottom: 0;
      padding-bottom: 0;
    }
    .my-bookings__detail dt {
      margin: 0;
      font-size: 1.2rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: #666;
    }
    .my-bookings__detail dd {
      margin: 0;
      font-size: 1.4rem;
      text-align: right;
      word-break: break-word;
    }
    .my-bookings__status {
      padding: 0.3rem 0.8rem;
      border-radius: 999px;
      font-size: 1.2rem;
      text-transform: uppercase;
    }
    .my-bookings__status--booked {
      background: #e8f5e9;
      color: #2e7d32;
    }
    .my-bookings__status--cancelled {
      background: #ffebee;
      color: #c62828;
    }
    .my-bookings__status--completed {
      background: #f5f5f5;
      color: #616161;
    }
  </style>

{% schema %}
{
    "name": "My Bookings",
    "settings": [],
    "presets":[{"name": "My Bookings"}]
}
{% endschema %}
{% comment %}
  Usage:
  {% render 'booking-details', booking: booking, order: order, customer: customer %}
{% endcomment %}

{% assign booking_customer = booking.customer.value %}
{% assign booking_order = booking.order_reference.value | default: booking.order.value %}
{% assign table_product = booking.table.value %}
{% assign table_image = table_product.featured_media | default: table_product.featured_image %}

<div class="booking-details__layout">
  {% if table_image %}
    <div class="booking-details__media">
      {{
        table_image
        | image_url: width: 1200
        | image_tag:
          loading: 'lazy',
          class: 'booking-details__image',
          alt: table_product.title
      }}
    </div>
  {% endif %}

  <div class="booking-details__content">
    <section class="booking-details__section">
      <h3 class="booking-details__section-title">Booking</h3>
      <dl class="booking-details__list">
        <div class="booking-details__row">
          <dt>Table</dt>
          <dd>{{ booking.table.value.title | default: '—' }}</dd>
        </div>
        <div class="booking-details__row">
          <dt>Date</dt>
          <dd>{{ booking.date.value | default: '—' }}</dd>
        </div>
      </dl>
    </section>

    <section class="booking-details__section">
      <h3 class="booking-details__section-title">Customer</h3>
      <dl class="booking-details__list">
        <div class="booking-details__row">
          <dt>Name</dt>
          <dd>
            {% if booking_customer.first_name != blank %}
              {{ booking_customer.first_name }} {{ booking_customer.last_name }}
            {% else %}
              {{ customer.name }}
            {% endif %}
          </dd>
        </div>
        <div class="booking-details__row">
          <dt>Email</dt>
          <dd>{{ booking.customer_email.value | default: booking_customer.email | default: customer.email }}</dd>
        </div>
      </dl>
    </section>

    <section class="booking-details__section">
      <h3 class="booking-details__section-title">Order</h3>
      <dl class="booking-details__list">
        <div class="booking-details__row">
          <dt>Reference</dt>
          <dd>{{ booking_order.name | default: order.name }}</dd>
        </div>
        <div class="booking-details__row">
          <dt>Order date</dt>
          <dd>{{ order.created_at | date: '%d %b %Y' }}</dd>
        </div>
        <div class="booking-details__row">
          <dt>Total</dt>
          <dd>{{ order.total_net_amount | money_with_currency }}</dd>
        </div>
      </dl>
    </section>
  </div>
</div>
